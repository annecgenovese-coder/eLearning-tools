<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sentence Builder</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&family=Open+Sans:wght@400;600;700&display=swap" rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Open Sans', sans-serif;
      font-size: 18px;
      font-weight: 600;
      background: #f0f7f7;
      color: #2d3748;
      min-height: 100vh;
      padding: 2rem 1rem;
    }

    .container {
      max-width: 700px;
      margin: 0 auto;
    }

    header {
      text-align: center;
      margin-bottom: 2rem;
    }

    header h1 {
      font-family: 'Montserrat', sans-serif;
      font-size: 2rem;
      font-weight: 800;
      color: #972b6a;
      margin-bottom: 0.5rem;
    }

    header p {
      color: #972b6acc;
      font-size: 1.1rem;
    }

    .game-card {
      background: #ffffff;
      border: 1px solid #e2e8f0;
      border-radius: 1rem;
      padding: 1.5rem 2rem;
      box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    }

    .progress-bar {
      height: 8px;
      background: #e2e8f0;
      border-radius: 4px;
      overflow: hidden;
      margin-bottom: 1.5rem;
    }

    .progress-fill {
      height: 100%;
      background: #2aa89a;
      border-radius: 4px;
      transition: width 0.5s ease;
    }

    .question h2 {
      font-family: 'Montserrat', sans-serif;
      font-size: 1.3rem;
      font-weight: 700;
      margin-bottom: 1.5rem;
    }

    .answer-label, .wordbank-label {
      font-size: 0.8rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: #2d374888;
      margin-bottom: 0.5rem;
    }

    .answer-area {
      min-height: 80px;
      background: #f7fafa;
      border: 2px dashed #e2e8f0;
      border-radius: 0.75rem;
      padding: 1rem;
      margin-bottom: 1rem;
      display: flex;
      flex-wrap: wrap;
      gap: 0.625rem;
      transition: all 0.2s;
    }

    .answer-area.has-words {
      border-color: #2aa89a80;
      background: #2aa89a08;
    }

    .answer-area.correct {
      background: #dcfce7;
      border: 2px solid #22c55e;
    }

    .answer-area.incorrect {
      background: #fee2e2;
      border: 2px solid #ef4444;
    }

    .answer-placeholder {
      color: #2d374866;
      width: 100%;
      text-align: center;
      padding: 0.5rem;
    }

    .word-bank {
      margin-bottom: 1.5rem;
    }

    .word-bank-words {
      display: flex;
      flex-wrap: wrap;
      gap: 0.625rem;
    }

    button.word {
      font-family: 'Open Sans', sans-serif;
      font-size: 1.125rem;
      font-weight: 600;
      padding: 0.625rem 1.5rem;
      border-radius: 0.5rem;
      cursor: pointer;
      transition: all 0.2s;
      border: 2px solid #cbd5e1;
      background: #f1f5f9;
      color: #7e2077;
    }

    button.word:hover:not(:disabled) {
      transform: scale(1.05);
      border-color: #2aa89a80;
      background: #2aa89a15;
    }

    button.word:disabled {
      opacity: 0.4;
      cursor: not-allowed;
      transform: none;
    }

    button.word.selected {
      background: #2aa89a;
      color: #ffffff;
      border-color: #2aa89a;
    }

    button.word.selected:hover:not(:disabled) {
      background: #2aa89add;
    }

    .feedback {
      padding: 1rem;
      border-radius: 0.75rem;
      margin-bottom: 1rem;
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
    }

    .feedback.correct {
      background: #dcfce7;
      border: 2px solid #22c55e;
      color: #166534;
    }

    .feedback.incorrect {
      background: #fee2e2;
      border: 2px solid #ef4444;
      color: #dc2626;
    }

    .feedback-icon {
      width: 24px;
      height: 24px;
      flex-shrink: 0;
    }

    .feedback-title {
      font-weight: 700;
    }

    .feedback-subtitle {
      font-size: 0.875rem;
      opacity: 0.8;
    }

    .hint-box {
      background: #fef3c7;
      border: 2px solid #f59e0b;
      color: #92400e;
      padding: 1rem;
      border-radius: 0.75rem;
      margin-bottom: 1rem;
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
    }

    .hint-icon {
      width: 20px;
      height: 20px;
      flex-shrink: 0;
    }

    .hint-title {
      font-weight: 700;
    }

    .hint-text {
      font-size: 0.875rem;
      opacity: 0.9;
    }

    .correct-answer-box {
      background: #f7fafa;
      border: 2px solid #e2e8f0;
      padding: 1rem;
      border-radius: 0.75rem;
      margin-bottom: 1rem;
    }

    .correct-answer-label {
      font-weight: 700;
      color: #2d374888;
      margin-bottom: 0.25rem;
    }

    .actions {
      display: flex;
      gap: 0.75rem;
    }

    .btn {
      font-family: 'Open Sans', sans-serif;
      font-size: 1rem;
      font-weight: 700;
      padding: 0.75rem 1.5rem;
      border-radius: 0.5rem;
      cursor: pointer;
      transition: all 0.2s;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      border: none;
    }

    .btn-primary {
      background: #2aa89a;
      color: #ffffff;
      flex: 2;
    }

    .btn-primary:hover:not(:disabled) {
      background: #2aa89add;
    }

    .btn-secondary {
      background: #e2e8f0;
      color: #2d3748;
      flex: 1;
    }

    .btn-secondary:hover:not(:disabled) {
      background: #e2e8f0dd;
    }

    .btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }

    .btn-full {
      width: 100%;
    }

    .sound-toggle {
      position: absolute;
      top: 1rem;
      right: 1rem;
      background: #ffffff;
      border: 2px solid #e2e8f0;
      border-radius: 0.5rem;
      width: 40px;
      height: 40px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.2s;
    }

    .sound-toggle:hover {
      border-color: #2aa89a;
    }

    .end-screen {
      text-align: center;
      padding: 2rem;
      position: relative;
      overflow: hidden;
    }

    .end-screen h2 {
      font-family: 'Montserrat', sans-serif;
      font-size: 2rem;
      font-weight: 800;
      margin-bottom: 1rem;
      position: relative;
      z-index: 10;
    }

    .score-display {
      font-size: 4rem;
      font-weight: 800;
      color: #2aa89a;
      margin: 1rem 0;
    }

    .score-percentage {
      font-size: 1.5rem;
      font-weight: 700;
      color: #2d374888;
    }

    .score-text {
      font-size: 1.2rem;
      color: #2d374888;
      margin-bottom: 1rem;
    }

    .end-content {
      position: relative;
      z-index: 10;
    }

    .dot-bar {
      display: flex;
      justify-content: center;
      gap: 0.5rem;
      flex-wrap: wrap;
      margin: 1.5rem 0;
      position: relative;
      z-index: 10;
    }

    .dot {
      width: 1rem;
      height: 1rem;
      border-radius: 50%;
      transition: all 0.3s;
    }

    .dot-success {
      background: #22c55e;
    }

    .dot-empty {
      background: #e2e8f0;
    }

    .confetti-container {
      position: absolute;
      inset: 0;
      pointer-events: none;
      overflow: hidden;
    }

    .confetti-piece {
      position: absolute;
      border-radius: 2px;
      opacity: 0.8;
    }

    @keyframes confetti-fall {
      0% {
        transform: translateY(0) rotate(0deg);
        opacity: 0.9;
      }
      10% {
        opacity: 0.9;
      }
      100% {
        transform: translateY(500px) rotate(720deg);
        opacity: 0;
      }
    }

    .hidden {
      display: none !important;
    }

    .game-wrapper {
      position: relative;
    }

    @keyframes shake {
      0%, 100% { transform: translateX(0); }
      20%, 60% { transform: translateX(-6px); }
      40%, 80% { transform: translateX(6px); }
    }

    @keyframes bounce-subtle {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-8px); }
    }

    @keyframes pop {
      0% { transform: scale(0.8); opacity: 0; }
      50% { transform: scale(1.1); }
      100% { transform: scale(1); opacity: 1; }
    }

    .animate-shake { animation: shake 0.5s ease-out; }
    .animate-bounce { animation: bounce-subtle 0.5s ease-out; }
    .animate-pop { animation: pop 0.3s ease-out; }
  </style>
</head>
<body>
  <div class="container">
    <header>
      <h1>Sentence Builder</h1>
      <p>Arrange the words to form correct sentences</p>
    </header>

    <main class="game-wrapper">
      <button class="sound-toggle" id="soundToggle" title="Toggle sound">
        <svg id="soundOnIcon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
          <path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"></path>
        </svg>
        <svg id="soundOffIcon" class="hidden" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
          <line x1="23" y1="9" x2="17" y2="15"></line>
          <line x1="17" y1="9" x2="23" y2="15"></line>
        </svg>
      </button>

      <div class="game-card" id="gameScreen">
        <div class="progress-bar">
          <div class="progress-fill" id="progressFill" style="width: 0%"></div>
        </div>

        <div class="question">
          <h2 id="questionPrompt">Arrange the words to form a correct sentence:</h2>
        </div>

        <div class="answer-label">Your Answer</div>
        <div class="answer-area" id="answerArea">
          <span class="answer-placeholder" id="answerPlaceholder">Click words from the bank to build your sentence</span>
        </div>

        <div id="feedbackArea"></div>

        <div class="word-bank">
          <div class="wordbank-label">Word Bank</div>
          <div class="word-bank-words" id="wordBank"></div>
        </div>

        <div class="actions" id="actionsArea">
          <button class="btn btn-secondary" id="clearBtn" disabled>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path>
              <path d="M3 3v5h5"></path>
            </svg>
            Clear
          </button>
          <button class="btn btn-primary" id="checkBtn" disabled>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            Check Answer
          </button>
        </div>
      </div>

      <div class="game-card end-screen hidden" id="endScreen">
        <div class="confetti-container" id="confettiContainer"></div>
        <div class="end-content">
          <h2 id="endMessage">Great Job!</h2>
          <p class="score-text">You scored</p>
          <div class="score-display" id="finalScore">0/0</div>
          <p class="score-percentage" id="scorePercentage">0%</p>
          <div class="dot-bar" id="dotBar"></div>
          <button class="btn btn-primary btn-full" id="restartBtn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path>
              <path d="M3 3v5h5"></path>
            </svg>
            Play Again
          </button>
        </div>
      </div>
    </main>
  </div>

  <script>
    const questions = [{"id":1,"prompt":"Arrange the words to form a correct sentence:","words":["of","difficulty","middle","the","lies","opportunity","In"],"correctAnswer":["In","the","middle","of","difficulty","lies","opportunity"],"hint":"Look for the opening inside the problem, not after it."},{"id":2,"prompt":"Arrange the words to form a correct sentence:","words":["in","you","change","Be","world","to","the","see","wish","the"],"correctAnswer":["Be","the","change","you","wish","to","see","in","the","world"],"hint":"Start with your own actions instead of waiting on others."},{"id":3,"prompt":"Arrange the words to form a correct sentence:","words":["Choose","over","comfort","courage"],"correctAnswer":["Choose","courage","over","comfort"],"hint":"Growth rarely happens in the easy option."}];
    
    let currentQuestionIndex = 0;
    let selectedWords = [];
    let score = 0;
    let isMuted = false;
    let audioContext = null;
    let wrongAttempts = 0;

    // DOM Elements
    const progressFill = document.getElementById('progressFill');
    const questionPrompt = document.getElementById('questionPrompt');
    const answerArea = document.getElementById('answerArea');
    const answerPlaceholder = document.getElementById('answerPlaceholder');
    const wordBank = document.getElementById('wordBank');
    const feedbackArea = document.getElementById('feedbackArea');
    const actionsArea = document.getElementById('actionsArea');

    // NOTE: These buttons get re-rendered via actionsArea.innerHTML (Next/Restart),
    // so we must always query them fresh instead of keeping stale references.
    const getCheckBtn = () => document.getElementById('checkBtn');
    const getClearBtn = () => document.getElementById('clearBtn');

    const gameScreen = document.getElementById('gameScreen');
    const endScreen = document.getElementById('endScreen');
    const endMessage = document.getElementById('endMessage');
    const finalScore = document.getElementById('finalScore');
    const scorePercentage = document.getElementById('scorePercentage');
    const dotBar = document.getElementById('dotBar');
    const confettiContainer = document.getElementById('confettiContainer');
    const restartBtn = document.getElementById('restartBtn');
    const soundToggle = document.getElementById('soundToggle');
    const soundOnIcon = document.getElementById('soundOnIcon');
    const soundOffIcon = document.getElementById('soundOffIcon');

    // Track which questions were answered correctly
    const answeredCorrectly = new Array(questions.length).fill(false);

    // Confetti colors from config
    const confettiColors = [
      '#2aa89a',
      '#22c55e',
      '#f59e0b',
      '#ef4444',
      '#2aa89a',
      '#cbd5e1'
    ];

    function initAudio() {
      if (!audioContext) {
        try {
          audioContext = new (window.AudioContext || window.webkitAudioContext)();
        } catch (e) {}
      }
      return audioContext;
    }

    function playTone(frequency, duration, type = 'sine') {
      if (isMuted) return;
      try {
        const ctx = initAudio();
        if (!ctx) return;
        const oscillator = ctx.createOscillator();
        const gainNode = ctx.createGain();
        oscillator.connect(gainNode);
        gainNode.connect(ctx.destination);
        oscillator.type = type;
        oscillator.frequency.setValueAtTime(frequency, ctx.currentTime);
        gainNode.gain.setValueAtTime(0.3, ctx.currentTime);
        gainNode.gain.exponentialRampToValueAtTime(0.01, ctx.currentTime + duration);
        oscillator.start(ctx.currentTime);
        oscillator.stop(ctx.currentTime + duration);
      } catch (e) {}
    }

    function playSound(type) {
      if (isMuted) return;
      switch (type) {
        case 'click':
          playTone(280, 0.12, 'triangle');
          break;
        case 'correct':
          playTone(523, 0.15, 'sine');
          setTimeout(() => playTone(659, 0.15, 'sine'), 100);
          setTimeout(() => playTone(784, 0.2, 'sine'), 200);
          break;
        case 'incorrect':
          playTone(200, 0.3, 'sawtooth');
          break;
        case 'complete':
          playTone(523, 0.15, 'sine');
          setTimeout(() => playTone(659, 0.15, 'sine'), 150);
          setTimeout(() => playTone(784, 0.15, 'sine'), 300);
          setTimeout(() => playTone(1047, 0.3, 'sine'), 450);
          break;
      }
    }

    function updateProgress() {
      const progress = (currentQuestionIndex / questions.length) * 100;
      progressFill.style.width = progress + '%';
    }

    function renderWordBank() {
      const question = questions[currentQuestionIndex];
      wordBank.innerHTML = '';
      
      const usedCounts = {};
      selectedWords.forEach(w => {
        usedCounts[w] = (usedCounts[w] || 0) + 1;
      });

      question.words.forEach((word, index) => {
        const wordCount = question.words.slice(0, index + 1).filter(w => w === word).length;
        const usedCount = usedCounts[word] || 0;
        const isUsed = wordCount <= usedCount;

        const btn = document.createElement('button');
        btn.className = 'word' + (isUsed ? ' ' : '');
        btn.textContent = word;
        btn.disabled = isUsed;
        btn.onclick = () => {
          if (!isUsed) {
            playSound('click');
            selectWord(word);
          }
        };
        wordBank.appendChild(btn);
      });
    }

    function renderAnswerArea() {
      answerArea.innerHTML = '';
      answerArea.className = 'answer-area';
      
      if (selectedWords.length === 0) {
        answerArea.innerHTML = '<span class="answer-placeholder">Click words from the bank to build your sentence</span>';
      } else {
        answerArea.classList.add('has-words');
        selectedWords.forEach((word, index) => {
          const btn = document.createElement('button');
          btn.className = 'word selected';
          btn.innerHTML = word + ' <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>';
          btn.onclick = () => {
            playSound('click');
            removeWord(index);
          };
          answerArea.appendChild(btn);
        });
      }

      const checkBtn = getCheckBtn();
      const clearBtn = getClearBtn();
      if (checkBtn) checkBtn.disabled = selectedWords.length === 0;
      if (clearBtn) clearBtn.disabled = selectedWords.length === 0;
    }

    function selectWord(word) {
      selectedWords.push(word);
      feedbackArea.innerHTML = '';
      wrongAttempts = 0;
      renderWordBank();
      renderAnswerArea();
    }

    function removeWord(index) {
      selectedWords.splice(index, 1);
      feedbackArea.innerHTML = '';
      wrongAttempts = 0;
      renderWordBank();
      renderAnswerArea();
    }

    function clearSelection() {
      selectedWords = [];
      feedbackArea.innerHTML = '';
      wrongAttempts = 0;
      renderWordBank();
      renderAnswerArea();
    }

    function checkAnswer() {
      const question = questions[currentQuestionIndex];
      const isCorrect = selectedWords.length === question.correctAnswer.length &&
        selectedWords.every((word, index) => word === question.correctAnswer[index]);

      if (isCorrect) {
        playSound('correct');
        score++;
        answeredCorrectly[currentQuestionIndex] = true;
        answerArea.classList.add('correct');
        
        feedbackArea.innerHTML = `
          <div class="feedback correct animate-bounce">
            <svg class="feedback-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
              <polyline points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
            <div>
              <div class="feedback-title">Excellent!</div>
              <div class="feedback-subtitle">You got it right!</div>
            </div>
          </div>
        `;

        actionsArea.innerHTML = `
          <button class="btn btn-primary btn-full" id="nextBtn">
            ${currentQuestionIndex === questions.length - 1 ? 'See Results' : 'Next Question'}
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </button>
        `;

        document.getElementById('nextBtn').onclick = nextQuestion;
      } else {
        playSound('incorrect');
        wrongAttempts++;
        answerArea.classList.add('incorrect');
        answerArea.classList.add('animate-shake');
        setTimeout(() => answerArea.classList.remove('animate-shake'), 500);

        let feedbackHtml = `
          <div class="feedback incorrect">
            <svg class="feedback-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"></circle>
              <line x1="15" y1="9" x2="9" y2="15"></line>
              <line x1="9" y1="9" x2="15" y2="15"></line>
            </svg>
            <div>
              <div class="feedback-title">Not quite right</div>
              <div class="feedback-subtitle">${wrongAttempts === 1 ? 'Try again or see the hint below' : 'The correct answer is shown below'}</div>
            </div>
          </div>
        `;

        if (wrongAttempts === 1 && question.hint) {
          feedbackHtml += `
            <div class="hint-box">
              <svg class="hint-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="1" x2="12" y2="3"></line>
                <line x1="12" y1="21" x2="12" y2="23"></line>
                <path d="M4.22 4.22l1.42 1.42"></path>
                <path d="M18.36 18.36l1.42 1.42"></path>
                <line x1="1" y1="12" x2="3" y2="12"></line>
                <line x1="21" y1="12" x2="23" y2="12"></line>
                <path d="M4.22 19.78l1.42-1.42"></path>
                <path d="M18.36 5.64l1.42-1.42"></path>
                <circle cx="12" cy="12" r="5"></circle>
              </svg>
              <div>
                <div class="hint-title">Hint</div>
                <div class="hint-text">${question.hint}</div>
              </div>
            </div>
          `;
        }

        if (wrongAttempts >= 2) {
          feedbackHtml += `
            <div class="correct-answer-box">
              <div class="correct-answer-label">Correct answer:</div>
              <div>${question.correctAnswer.join(' ')}</div>
            </div>
          `;
        }

        feedbackArea.innerHTML = feedbackHtml;
      }
    }

    function nextQuestion() {
      playSound('click');
      currentQuestionIndex++;
      wrongAttempts = 0;
      
      if (currentQuestionIndex >= questions.length) {
        showEndScreen();
      } else {
        selectedWords = [];
        feedbackArea.innerHTML = '';
        actionsArea.innerHTML = `
          <button class="btn btn-secondary" id="clearBtn" disabled>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path>
              <path d="M3 3v5h5"></path>
            </svg>
            Clear
          </button>
          <button class="btn btn-primary" id="checkBtn" disabled>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            Check Answer
          </button>
        `;
        document.getElementById('clearBtn').onclick = clearSelection;
        document.getElementById('checkBtn').onclick = checkAnswer;
        
        updateProgress();
        renderWordBank();
        renderAnswerArea();
      }
    }

    function showEndScreen() {
      playSound('complete');
      gameScreen.classList.add('hidden');
      endScreen.classList.remove('hidden');
      
      // Update message based on percentage
      const percentage = Math.round((score / questions.length) * 100);
      if (percentage === 100) {
        endMessage.textContent = 'Perfect Score!';
      } else if (percentage >= 80) {
        endMessage.textContent = 'Excellent Work!';
      } else if (percentage >= 60) {
        endMessage.textContent = 'Good Job!';
      } else {
        endMessage.textContent = 'Keep Practicing!';
      }
      
      finalScore.textContent = score + '/' + questions.length;
      scorePercentage.textContent = percentage + '%';
      
      // Render dot bar
      dotBar.innerHTML = '';
      for (let i = 0; i < questions.length; i++) {
        const dot = document.createElement('div');
        dot.className = 'dot ' + (answeredCorrectly[i] ? 'dot-success' : 'dot-empty');
        dotBar.appendChild(dot);
      }
      
      // Generate confetti
      confettiContainer.innerHTML = '';
      for (let i = 0; i < 50; i++) {
        const piece = document.createElement('div');
        piece.className = 'confetti-piece';
        const size = 6 + Math.random() * 8;
        const delay = Math.random() * 3;
        const duration = 4 + Math.random() * 3;
        piece.style.cssText = `
          left: ${Math.random() * 100}%;
          top: -20px;
          width: ${size}px;
          height: ${size}px;
          background: ${confettiColors[Math.floor(Math.random() * confettiColors.length)]};
          animation: confetti-fall ${duration}s linear ${delay}s infinite;
        `;
        confettiContainer.appendChild(piece);
      }
    }

    function restart() {
      playSound('click');
      currentQuestionIndex = 0;
      selectedWords = [];
      score = 0;
      wrongAttempts = 0;
      
      gameScreen.classList.remove('hidden');
      endScreen.classList.add('hidden');
      feedbackArea.innerHTML = '';
      
      actionsArea.innerHTML = `
        <button class="btn btn-secondary" id="clearBtn" disabled>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path>
            <path d="M3 3v5h5"></path>
          </svg>
          Clear
        </button>
        <button class="btn btn-primary" id="checkBtn" disabled>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
          Check Answer
        </button>
      `;
      document.getElementById('clearBtn').onclick = clearSelection;
      document.getElementById('checkBtn').onclick = checkAnswer;
      
      updateProgress();
      renderWordBank();
      renderAnswerArea();
    }

    function toggleMute() {
      isMuted = !isMuted;
      soundOnIcon.classList.toggle('hidden', isMuted);
      soundOffIcon.classList.toggle('hidden', !isMuted);
      if (!isMuted) {
        playTone(600, 0.1, 'sine');
      }
    }

    // Initialize
    soundToggle.onclick = toggleMute;
    const clearBtn = getClearBtn();
    const checkBtn = getCheckBtn();
    if (clearBtn) clearBtn.onclick = clearSelection;
    if (checkBtn) checkBtn.onclick = checkAnswer;
    restartBtn.onclick = restart;

    updateProgress();
    renderWordBank();
    renderAnswerArea();
  </script>
</body>
</html>
